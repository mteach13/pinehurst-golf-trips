---
const sections = [
  { label: 'When to Go', slug: 'when-to-go' },
  { label: 'How to Book', slug: 'how-to-book' },
  { label: 'What It Costs', slug: 'what-it-costs' },
  { label: 'The Caddie Experience', slug: 'the-caddie-experience' },
  { label: 'Building Your Itinerary', slug: 'building-your-itinerary' },
  { label: 'What to Know', slug: 'what-to-know' },
  { label: 'FAQ', slug: 'faq' },
];
---

<nav aria-label="Guide navigation" class="course-nav-scroll sticky top-16 max-h-[calc(100vh-5rem)] overflow-y-auto pr-2">
  <p class="text-xs font-semibold uppercase tracking-widest text-olive mb-4">On this page</p>
  <ul class="space-y-2 pl-3">
    {sections.map(({ label, slug }) => (
      <li data-nav-target={slug} class="border-l-2 border-dark-green/10 pl-3">
        <a
          href={`#${slug}`}
          class="guide-nav-link text-sm font-semibold text-dark-green/60 hover:text-dark-green transition-colors block py-0.5"
          data-target={slug}
        >
          {label}
        </a>
      </li>
    ))}
  </ul>
</nav>

<script>
  const links = document.querySelectorAll<HTMLAnchorElement>('.guide-nav-link');
  const targets = new Map<string, HTMLElement>();

  links.forEach((link) => {
    const id = link.dataset.target;
    if (id) {
      const el = document.getElementById(id);
      if (el) targets.set(id, el);
    }
  });

  let activeId = '';

  function setActive(id: string) {
    if (id === activeId) return;
    activeId = id;

    links.forEach((link) => {
      const li = link.closest('li[data-nav-target]') as HTMLElement;
      const isActive = link.dataset.target === activeId;

      if (isActive) {
        link.classList.remove('text-dark-green/60');
        link.classList.add('text-dark-green', 'font-bold');
        li?.classList.remove('border-dark-green/10');
        li?.classList.add('border-olive');
      } else {
        link.classList.add('text-dark-green/60');
        link.classList.remove('text-dark-green', 'font-bold');
        li?.classList.add('border-dark-green/10');
        li?.classList.remove('border-olive');
      }
    });
  }

  const observer = new IntersectionObserver(
    (entries) => {
      let topId = '';
      let topY = Infinity;

      for (const entry of entries) {
        if (entry.isIntersecting && entry.boundingClientRect.top < topY) {
          topY = entry.boundingClientRect.top;
          topId = entry.target.id;
        }
      }

      if (topId) setActive(topId);
    },
    { rootMargin: '-80px 0px -60% 0px', threshold: 0 }
  );

  targets.forEach((el) => observer.observe(el));
</script>
