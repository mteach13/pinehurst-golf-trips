---
const navLinks = [
  { href: '/courses', label: 'Courses' },
  { href: '/guide', label: 'Guide' },
  { href: '/contact', label: 'Contact' },
  { href: '/about', label: 'About' },
];

const currentPath = Astro.url.pathname;
---

<header class="absolute top-0 left-0 right-0 z-50 px-6 pt-4">
  <nav class="mx-auto max-w-5xl bg-cream rounded-full px-8 pt-4 pb-3 flex items-baseline justify-between shadow-[0_4px_20px_rgba(0,0,0,0.15)]">
    <a href="/" class="font-heading text-xl font-bold tracking-tight text-dark-green hover:text-olive transition-colors">
      Pinehurst Golf Trips
    </a>

    {/* Desktop nav */}
    <ul class="hidden md:flex items-baseline gap-8">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              'text-sm font-medium tracking-wide uppercase transition-colors',
              currentPath === href || currentPath.startsWith(href + '/')
                ? 'text-olive'
                : 'text-dark-green/70 hover:text-dark-green',
            ]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    {/* Mobile menu button */}
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 -mr-2 text-dark-green"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        <path id="close-icon" class="hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </nav>

  {/* Mobile menu */}
  <div id="mobile-menu" class="hidden md:hidden mx-auto max-w-5xl mt-2 bg-cream rounded-2xl shadow-[0_4px_20px_rgba(0,0,0,0.15)] px-8 py-4">
    <ul class="space-y-3">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              'block text-sm font-medium tracking-wide uppercase transition-colors',
              currentPath === href || currentPath.startsWith(href + '/')
                ? 'text-olive'
                : 'text-dark-green/70 hover:text-dark-green',
            ]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');

  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    btn.setAttribute('aria-expanded', String(isOpen));
    menuIcon?.classList.toggle('hidden', isOpen);
    closeIcon?.classList.toggle('hidden', !isOpen);
  });
</script>
