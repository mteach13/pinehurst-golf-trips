---
const navLinks = [
  { href: '/courses', label: 'Courses' },
  { href: '/guide', label: 'Guide' },
  { href: '/contact', label: 'Contact' },
  { href: '/about', label: 'About' },
];

const currentYear = new Date().getFullYear();
---

<footer class="bg-dark-green text-cream/80 mt-24">
  <div class="mx-auto max-w-5xl px-6 py-12">
    <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-8">
      {/* Brand */}
      <div class="max-w-sm">
        <a href="/" class="text-xl font-bold text-cream no-underline hover:text-cream/90 transition-colors">
          Pinehurst Golf Trips
        </a>
        <p class="mt-3 text-sm leading-relaxed text-cream/60">
          The independent, opinionated guide to planning a golf trip in the Sandhills of North Carolina.
        </p>
      </div>

      {/* Nav */}
      <nav aria-label="Footer navigation">
        <ul class="flex gap-6">
          {navLinks.map(({ href, label }) => (
            <li>
              <a
                href={href}
                class="text-sm text-cream/60 no-underline hover:text-cream transition-colors"
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>

    <div class="mt-10 pt-6 border-t border-cream/10 text-sm text-cream/40">
      &copy; {currentYear} Pinehurst Golf Trips. Not affiliated with Pinehurst Resort.
    </div>
  </div>
</footer>
